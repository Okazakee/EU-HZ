{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ingestRequest",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/ingestItem" }
    }
  },
  "required": ["items"],
  "$defs": {
    "ingestItem": {
      "type": "object",
      "properties": {
        "xHandle": { "type": "string" },
        "xPostId": { "type": "string" },
        "xPostUrl": { "type": "string" },
        "xPostedAt": { "type": "string", "format": "date-time" },
        "title": { "type": "string", "maxLength": 120 },
        "summary": { "type": "string", "maxLength": 220 },
        "eventType": { "type": "string", "enum": ["harassment", "robbery", "assault", "violence"] },
        "location": { "type": "string" },
        "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "city": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 0.8 }
      },
      "required": ["xHandle", "xPostId", "xPostUrl", "xPostedAt", "title", "summary", "eventType", "location", "countryCode", "city", "confidence"]
    }
  }
}

# Backend API
DATABASE_URL=postgres://heatmap:heatmap@postgres:5432/heatmap?sslmode=disable
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://euhz.vercel.app

# Ingest worker
INGEST_KEY=change-me
INGEST_MODEL=opencode/deepseek-v4-flash-free
INGEST_INTERVAL=24h

# Postgres container
POSTGRES_DB=heatmap
POSTGRES_USER=heatmap
POSTGRES_PASSWORD=heatmap

# Frontend
# Copy this value into apps/web/.env.local for local Next.js dev,
# or set it in Vercel project environment variables.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
